# Required only for the full Discord service. The console demo does not use it.
DISCORD_TOKEN=
# Required only when configured models use the Anthropic provider.
ANTHROPIC_API_KEY=
# Required for the free console demo and whenever configured models use Gemini.
GOOGLE_API_KEY=
# Required only when configured models use the OpenAI provider.
OPENAI_API_KEY=
# Optional: required only by the web_search tool.
BRAVE_API_KEY=
