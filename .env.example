# Required only when channel.provider is discord. The local channel and demo do not use it.
DISCORD_TOKEN=
# Optional shared-token gate for local chat. Recommended when DASHBOARD_HOST is
# not loopback; use a TLS reverse proxy whenever exposing the service remotely.
LOCAL_CHANNEL_TOKEN=
# Required only when configured models use the Anthropic provider.
ANTHROPIC_API_KEY=
# Used whenever configured models use Gemini. If blank, the interactive local
# demo prompts for a key and keeps it in memory for that run only.
GOOGLE_API_KEY=
# Optional non-interactive demo persona override (for example, the-general).
NEWSTEAM_DEMO_PERSONA=
# Required only when configured models use the OpenAI provider.
OPENAI_API_KEY=
# Optional: required only by the web_search tool.
BRAVE_API_KEY=
