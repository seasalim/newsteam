# Required only for the full Discord service. The console demo does not use it.
DISCORD_TOKEN=
# Required only when configured models use the Anthropic provider.
ANTHROPIC_API_KEY=
# Used whenever configured models use Gemini. If blank, the interactive console
# demo prompts for a key and keeps it in memory for that run only.
GOOGLE_API_KEY=
# Optional non-interactive console demo persona override (for example, the-general).
NEWSTEAM_DEMO_PERSONA=
# Required only when configured models use the OpenAI provider.
OPENAI_API_KEY=
# Optional: required only by the web_search tool.
BRAVE_API_KEY=
