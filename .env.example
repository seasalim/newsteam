# Required: Discord bot token used to connect the bot.
DISCORD_TOKEN=your-discord-bot-token
# Required only when configured models use the Anthropic provider.
ANTHROPIC_API_KEY=your-anthropic-api-key
# Required only when configured models use the Google Gemini provider.
GOOGLE_API_KEY=your-google-api-key
# Required only when configured models use the OpenAI provider.
OPENAI_API_KEY=your-openai-api-key
# Optional: required only by the web_search tool.
BRAVE_API_KEY=your-brave-api-key
