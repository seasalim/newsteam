{
  "name": "web_search",
  "description": "Search the web. Returns titles, URLs, and snippets for a given query.",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query",
        "maxLength": 200
      },
      "count": {
        "type": "number",
        "description": "Number of results (1-5)",
        "minimum": 1,
        "maximum": 5,
        "default": 3
      }
    },
    "required": ["query"]
  },
  "secrets": ["BRAVE_API_KEY"],
  "timeout_ms": 5000,
  "handler": "handler.py",
  "runtime": "python"
}
